{
  "name": "mcp-gtm-ga4",
  "mcpName": "io.github.mharnett/gtm-ga4",
  "version": "1.0.10",
  "description": "MCP server for Google Tag Manager + GA4 with sandbox safety, consent auditing, and multi-client support.",
  "main": "dist/index.js",
  "bin": {
    "mcp-gtm-ga4": "dist/index.js"
  },
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc && node -e \"fs=require('fs');cp=require('child_process');sha=cp.execSync('git rev-parse --short HEAD 2>/dev/null||echo unknown').toString().trim();fs.writeFileSync('dist/build-info.json',JSON.stringify({sha,builtAt:new Date().toISOString()}))\"",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "config.example.json"
  ],
  "author": "drak-marketing",
  "license": "MIT",
  "engines": {
    "node": ">=18.18.0"
  },
  "dependencies": {
    "@google-analytics/admin": "^9.0.1",
    "@google-analytics/data": "^5.2.1",
    "@modelcontextprotocol/sdk": "^0.5.0",
    "cockatiel": "^3.2.1",
    "google-auth-library": "^9.14.0",
    "googleapis": "^144.0.0",
    "pino": "^8.21.0",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  }
}
